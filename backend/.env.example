# Copiez ce fichier vers .env et remplissez les valeurs réelles.
# Ne commitez JAMAIS le fichier .env (il est dans .gitignore).

# --- Base de données ---
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/francais_ia

# --- Redis (cache + rate limiting) ---
REDIS_URL=redis://localhost:6379/0

# --- Sécurité / JWT ---
# Générez une valeur forte, par ex. : python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET_KEY=changez-moi-avec-une-cle-secrete-forte-generee-aleatoirement
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# --- LLM (API compatible OpenAI) ---
# Par défaut : Groq (gratuit, tier généreux). Clé sur https://console.groq.com/keys
# Pour utiliser DeepSeek à la place :
#   LLM_BASE_URL=https://api.deepseek.com/v1
#   LLM_MODEL=deepseek-chat
# Pour utiliser Ollama en local (aucune clé requise) :
#   LLM_API_KEY=ollama
#   LLM_BASE_URL=http://localhost:11434/v1
#   LLM_MODEL=llama3.2
LLM_API_KEY=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
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_MODEL=llama-3.3-70b-versatile
LLM_TIMEOUT_SECONDS=30
LLM_MAX_RETRIES=3

# --- CORS ---
# Liste d'origines autorisées séparées par des virgules
CORS_ORIGINS=http://localhost:3000

# --- Rate limiting ---
CHAT_RATE_LIMIT_PER_MINUTE=20
SPEECH_RATE_LIMIT_PER_MINUTE=10

# --- Speech-to-Text (faster-whisper, local) ---
STT_MODEL_SIZE=small
STT_DEVICE=cpu
STT_COMPUTE_TYPE=int8

# --- Text-to-Speech (edge-tts) ---
TTS_VOICE=fr-FR-DeniseNeural

# --- Logging structuré (Phase 8) ---
# "text" (lisible, dev) ou "json" (pour agrégateurs de logs en prod)
LOG_FORMAT=text
