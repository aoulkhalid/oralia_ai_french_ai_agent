# Base de données
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/francais_ia

# Redis
REDIS_URL=redis://localhost:6379/0

# Clé API Gemini (à remplir) - https://aistudio.google.com/apikey
GEMINI_API_KEY=
# Modèle utilisé pour la conversation, la correction et la transcription (STT)
GEMINI_MODEL=gemini-2.5-flash
# Modèle utilisé pour la synthèse vocale (TTS)
GEMINI_TTS_MODEL=gemini-2.5-flash-preview-tts
# Voix Gemini TTS (ex: Kore, Puck, Charon, Zephyr, ...)
GEMINI_TTS_VOICE=Kore

# Sécurité / JWT
SECRET_KEY=change-moi-en-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
